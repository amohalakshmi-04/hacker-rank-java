import java.io.*;
import java.util.*;
import java.text.*;
import java.math.*;
import java.util.regex.*;

public class Solution {

    public static void main(String[] args) {
        /* Enter your code here. Read input from STDIN. Print output to STDOUT. Your class should be named Solution. */
        Scanner sc = new Scanner(System.in);
        int n = sc.nextInt();
        int[] a = new int[n];
        
        for (int i = 0; i < n; i++) {
            a[i] = sc.nextInt();
        }
        sc.close();
        
        int negativeSubarrays = 0;
        
        // Start index of the subarray
        for (int i = 0; i < n; i++) {
            int currentSum = 0;
            // End index of the subarray
            for (int j = i; j < n; j++) {
                currentSum += a[j];
                if (currentSum < 0) {
                    negativeSubarrays++;
                }
            }
        }
        
        System.out.println(negativeSubarrays);
    
    }
}
