import java.util.*;
import java.io.*;

class Solution{
	public static void main(String []argh)
	{
		Scanner in = new Scanner(System.in);
        
        // 1. Initialize the HashMap
        Map<String, Integer> phoneBook = new HashMap<>();
        
        // 2. Read 'n' entries and store them in the map
        int n = in.nextInt();
        in.nextLine(); // Consume the newline after n
        
        for (int i = 0; i < n; i++) {
            String name = in.nextLine();
            int phone = in.nextInt();
            in.nextLine(); // Consume the newline after phone number
            
            phoneBook.put(name, phone);
        }
        
        // 3. Process queries until the end of input
        while (in.hasNext()) {
            String s = in.nextLine();
            
            if (phoneBook.containsKey(s)) {
                // Entry exists: print name=phone
                System.out.println(s + "=" + phoneBook.get(s));
            } else {
                // Entry does not exist
                System.out.println("Not found");
            }
        }
    }
}

