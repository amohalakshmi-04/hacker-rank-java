import java.util.*;

public class Solution {

    public static boolean canWin(int leap, int[] game) {
         // We start the game at index 0
        return isSolvable(leap, game, 0);
    }

    // Helper method to handle the recursive movement
    private static boolean isSolvable(int leap, int[] game, int i) {
        // 1. Check if we jumped off the end (Win condition)
        if (i >= game.length) {
            return true;
        }
        // 2. Check if we are out of bounds or on a 1 (Lose/Invalid move)
        if (i < 0 || game[i] == 1) {
            return false;
        }

        // 3. Mark the current cell as 1 so we don't visit it again (prevents infinite loops)
        game[i] = 1;

        // 4. Try all 3 possible moves: jump forward, walk forward, walk backward
        return isSolvable(leap, game, i + leap) || 
               isSolvable(leap, game, i + 1) || 
               isSolvable(leap, game, i - 1);
        // Return true if you can win the game; otherwise, return false.
    }

    public static void main(String[] args) {
        Scanner scan = new Scanner(System.in);
        int q = scan.nextInt();
        while (q-- > 0) {
            int n = scan.nextInt();
            int leap = scan.nextInt();
            
            int[] game = new int[n];
            for (int i = 0; i < n; i++) {
                game[i] = scan.nextInt();
            }

            System.out.println( (canWin(leap, game)) ? "YES" : "NO" );
        }
        scan.close();
    }
}
